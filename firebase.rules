rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function listingOwner() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function creatingOwnListing() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if creatingOwnListing();
      allow update, delete: if listingOwner();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read, create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if signedIn();
        allow update, delete: if false;
      }
    }

    match /favorites/{favoriteId} {
      allow read, create, update, delete: if signedIn();
    }

    match /subscriptions/{subscriptionId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
